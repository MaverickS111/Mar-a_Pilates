# ─────────────────────────────────────────────
#  María Pilates — Variables de entorno
# ─────────────────────────────────────────────

# Puerto del servidor (por defecto 3001)
PORT=3001

# URL del frontend (para la config de CORS)
# En producción: https://tu-dominio.com
# En desarrollo: * (o la dirección local)
FRONTEND_URL=*

# ── Google Service Account ──────────────────
# Obtenidos del archivo JSON descargado desde Google Cloud Console

GOOGLE_CLIENT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com

# Pega la clave privada completa (incluyendo saltos de línea como \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvA...\n-----END PRIVATE KEY-----\n"

# ID del calendario de Google Calendar compartido con la Service Account
# Puede ser tu email (calendario principal) o algo como abc123@group.calendar.google.com
GOOGLE_CALENDAR_ID=tu_email@gmail.com

# ── Horario de trabajo ──────────────────────
# Días de trabajo (0=dom, 1=lun, ... 6=sáb)
WORKING_DAYS=1,2,3,4,5,6

# Hora de inicio y fin (formato HH:MM, 24h)
SLOT_START=09:00
SLOT_END=20:00

# Duración de cada sesión en minutos
SLOT_DURATION=60
